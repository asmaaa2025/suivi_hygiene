    "rules": [
      {
        "id": "temp_no_device_selected",
        "event_type": "temperature.logged",
        "when": [{ "path": "device_id", "op": "exists", "value": false }],
        "emit": [{ "alert_code": "TEMP.NO_DEVICE_SELECTED" }]
      },
      {
        "id": "temp_threshold_missing",
        "event_type": "temperature.logged",
        "when": [
          { "path": "device_id", "op": "exists", "value": true },
          { "path": "device_thresholds_missing", "op": "eq", "value": true }
        ],
        "emit": [{ "alert_code": "TEMP.DEVICE_THRESHOLD_MISSING" }]
      },
      {
        "id": "temp_out_of_range_warn",
        "event_type": "temperature.logged",
        "when": [
          { "path": "temperature_c", "op": "exists", "value": true },
          { "path": "temp_out_of_range", "op": "eq", "value": true },
          { "path": "temp_is_critical", "op": "eq", "value": false }
        ],
        "emit": [{ "alert_code": "TEMP.OUT_OF_RANGE_WARN" }]
      },
      {
        "id": "temp_out_of_range_critical",
        "event_type": "temperature.logged",
        "when": [
          { "path": "temperature_c", "op": "exists", "value": true },
          { "path": "temp_is_critical", "op": "eq", "value": true }
        ],
        "emit": [{ "alert_code": "TEMP.OUT_OF_RANGE_CRITICAL" }]
      },
      {
        "id": "reception_wet_carton",
        "event_type": "reception.checked",
        "when": [{ "path": "packaging.issue", "op": "eq", "value": "wet_carton" }],
        "emit": [{ "alert_code": "RECEPT.PACKAGING_WET_CARTON" }]
      },
      {
        "id": "reception_seal_broken",
        "event_type": "reception.checked",
        "when": [{ "path": "packaging.issue", "op": "in", "value": ["open_packaging", "broken_seal"] }],
        "emit": [{ "alert_code": "RECEPT.PACKAGING_SEAL_BROKEN" }]
      },
      {
        "id": "reception_missing_label_fields_warn",
        "event_type": "reception.checked",
        "when": [
          { "path": "label.missing_fields_count", "op": "gt", "value": 0 },
          { "path": "label.missing_fields_count", "op": "lte", "value": 2 }
        ],
        "emit": [{ "alert_code": "RECEPT.MISSING_LABEL_FIELDS" }]
      },
      {
        "id": "reception_missing_label_fields_critical",
        "event_type": "reception.checked",
        "when": [{ "path": "label.missing_fields_count", "op": "gt", "value": 2 }],
        "emit": [{ "alert_code": "RECEPT.MISSING_LABEL_FIELDS_CRITICAL" }]
      },
      {
        "id": "oil_quality_critical",
        "event_type": "oil.check_logged",
        "when": [{ "path": "oil_state", "op": "in", "value": ["dark", "foamy", "smoke", "bad_smell"] }],
        "emit": [{ "alert_code": "OIL.QUALITY_CRITICAL" }]
      },
      {
        "id": "clean_missed_task",
        "event_type": "cleaning.day_closed",
        "when": [{ "path": "missed_count", "op": "gt", "value": 0 }],
        "emit": [{ "alert_code": "CLEAN.MISSED_TASK" }]
      },
      {
        "id": "clean_multiple_missed_tasks_critical",
        "event_type": "cleaning.day_closed",
        "when": [{ "path": "missed_count", "op": "gte", "value": 3 }],
        "emit": [{ "alert_code": "CLEAN.MULTIPLE_MISSED_TASKS_CRITICAL" }]
      },
      {
        "id": "compliance_due_soon",
        "event_type": "compliance.daily_check",
        "when": [
          { "path": "status", "op": "eq", "value": "dueSoon" }
        ],
        "emit": [{ "alert_code": "DOCS.COMPLIANCE_DUE_SOON" }]
      },
      {
        "id": "compliance_overdue",
        "event_type": "compliance.daily_check",
        "when": [
          { "path": "status", "op": "eq", "value": "overdue" }
        ],
        "emit": [{ "alert_code": "DOCS.COMPLIANCE_OVERDUE" }]
      }
    ]
  }
  